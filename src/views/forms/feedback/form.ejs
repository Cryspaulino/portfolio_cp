<%- include('../../partials/header') %>
    <main>
        <h1>Share your thoughts!</h1>
        <p>
            Have any feedback or insights about my projects? Send a response in the form below and I will work on new program ideas.
        </p>

        <form method="POST" action="/feedback" class="contact-form">
            <div class="form-group">
                <label for="subject">Project</label>
                <input type="text" id="subject" name="subject" placeholder="What project is this comment about?" required>
            </div>

            <div class="form-group">
                <label for="message">Insights</label>
                <textarea id="message" name="message" rows="6"
                    placeholder="Please provide your feedback..." minlength="10"
                    required></textarea>
            </div>

            <button type="submit">Send Feedback</button>
        </form>
    </main>
    <%- include('../../partials/footer') %>