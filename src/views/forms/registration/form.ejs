<%- include('../../partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>
        Register for a new account by providing your information below. All fields are required and passwords must meet security requirements.
    </p>

    <form method="POST" action="/register" class="registration-form">
        <!-- Name field -->
        <!-- Add label for="name" -->
        <!-- Add input type="text" id="name" name="name" -->
        <!-- Add minlength="2" and required attributes -->
        <!-- Add appropriate placeholder text -->
        <div class="form-group">
            <label for="name">Name</label>
             <input type="text" id="name" name="name" minlength="2" placeholder="Enter your name here" required>
        </div>

        <!-- Email field -->
        <!-- Create form-group div -->
        <!-- Add label for email -->
        <!-- Add input type="email" with id, name, and required -->
         <div class="form-group">
            <label for="email">Email</label>
             <input type="email" id="email" name="email" required placeholder="Enter your email">
        </div>

        <!-- Email confirmation field -->
        <!-- Create form-group div for emailConfirm -->
        <!-- Should match email field structure -->
        <!-- Use name="emailConfirm" -->
         <div class="form-group">
            <label for="email">Confirm Email</label>
             <input type="email" id="emailconfirm" name="emailConfirm" required placeholder="Please enter your email again">
        </div>

        <!-- Password field -->
        <!-- Create form-group div -->
        <!-- Add label for password -->
        <!-- Add input type="password" -->
        <!-- Add minlength="8" and required attributes -->
        <!-- Add pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*" for validation -->
        <!-- Add a div with class="help-text" explaining requirements -->
        <!-- HINT: "Must be at least 8 characters with a number and special character" -->
         <div class="form-group">
            <label for="password">Password</label>
             <input type="password" id="password" name="password" minlength="8" pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*"  placeholder="Enter your password here" required>
        </div>
        <div class="help-text">
            <p>Your password must be at least 8 characters with a number and special character</p>
        </div>

        <!-- Password confirmation field -->
        <!-- Similar to password field but for passwordConfirm -->
        <!-- Use name="passwordConfirm" and appropriate label -->
        <div class="form-group">
            <label for="password">Confirm Password</label>
             <input type="password" id="passwordconfirm" name="passwordConfirm" minlength="8" pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*"  placeholder="Please enter your password again" required>
        </div>
        <!-- Submit button -->
        <!-- Add button type="submit" with text like "Create Account" -->
         <button type="submit">Create Account</button>
    </form>
</main>
<%- include('../../partials/footer') %>