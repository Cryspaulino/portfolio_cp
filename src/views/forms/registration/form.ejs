<%- include('../../partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>
        Register for a new account by providing your information below. All fields are required and passwords must meet security requirements.
    </p>

    <form method="POST" action="/register" class="registration-form">
        <div class="form-group">
            <label for="name">Name</label>
             <input type="text" id="name" name="name" minlength="2" placeholder="Enter your name here" required>
        </div>
         <div class="form-group">
            <label for="email">Email</label>
             <input type="email" id="email" name="email" required placeholder="Enter your email">
        </div>
         <div class="form-group">
            <label for="email">Confirm Email</label>
             <input type="email" id="emailconfirm" name="emailConfirm" required placeholder="Please enter your email again">
        </div>
         <div class="form-group">
            <label for="password">Password</label>
             <input type="password" id="password" name="password" minlength="8" pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*"  placeholder="Enter your password here" required>
        </div>
        <div class="help-text">
            <p>Your password must be at least 8 characters with a number and special character</p>
        </div>
        <div class="form-group">
            <label for="password">Confirm Password</label>
             <input type="password" id="passwordconfirm" name="passwordConfirm" minlength="8" pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*"  placeholder="Please enter your password again" required>
        </div>
         <button type="submit">Create Account</button>
    </form>
</main>
<%- include('../../partials/footer') %>